# ─── Mode Démo ─────────────────────────────────────────────────────────────────
# Mettre à "true" pour forcer le mode démo (sans Supabase) pour tout le monde.
# Sinon, le mode démo peut être activé par chaque utilisateur depuis la page /connexion.
NEXT_PUBLIC_DEMO_MODE=false

# ─── Supabase (requis en mode production) ───────────────────────────────────────
# Laisser vide ou avec les valeurs "placeholder" pour rester en mode démo.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
